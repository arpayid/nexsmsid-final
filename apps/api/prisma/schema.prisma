generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id                            String                 @id @default(cuid())
  email                         String                 @unique
  username                      String?                @unique
  name                          String
  passwordHash                  String                 @map("password_hash")
  status                        UserStatus             @default(ACTIVE)
  forceChangePassword           Boolean                @default(false) @map("force_change_password")
  passwordChangedAt             DateTime?              @map("password_changed_at")
  lockedUntil                   DateTime?              @map("locked_until")
  failedLoginCount              Int                    @default(0) @map("failed_login_count")
  lastLoginAt                   DateTime?              @map("last_login_at")
  createdAt                     DateTime               @default(now()) @map("created_at")
  updatedAt                     DateTime               @updatedAt @map("updated_at")
  deletedAt                     DateTime?              @map("deleted_at")
  roles                         UserRole[]
  refreshTokens                 RefreshToken[]
  loginHistories                LoginHistory[]
  auditLogs                     AuditLog[]             @relation("AuditActor")
  verifiedPayments              Payment[]              @relation("VerifiedPayments")
  approvedExpenses              Expense[]              @relation("ApprovedExpenses")
  ppdbRegistrations             PpdbRegistration[]     @relation("PpdbVerifier")
  ppdbStatusChanges             PpdbStatusHistory[]    @relation("PpdbStatusChanger")
  reviewedInternshipLogs        InternshipLog[]        @relation("InternshipLogReviewer")
  assessedInternshipScores      InternshipScore[]      @relation("InternshipScoreAssessor")
  createdAnnouncements          Announcement[]         @relation("AnnouncementCreator")
  sentMessages                  InternalMessage[]      @relation("InternalMessageSender")
  receivedMessages              InternalMessage[]      @relation("InternalMessageRecipient")
  readMessages                  InternalMessage[]      @relation("InternalMessageReader")
  notifications                 Notification[]
  createdNotificationTemplates  NotificationTemplate[] @relation("NotificationTemplateCreator")
  reportJobs                    ReportJob[]            @relation("ReportJobRequester")
  exportHistories               ExportHistory[]        @relation("ExportHistoryRequester")
  teacherProfile                Teacher?               @relation("TeacherUser")
  studentProfile                Student?               @relation("StudentUser")
  guardianProfile               Guardian?              @relation("GuardianUser")
  counselingCasesCounselor      CounselingCase[]       @relation("CounselingCaseCounselor")
  counselingCasesCreated        CounselingCase[]       @relation("CounselingCaseCreatedBy")
  counselingCasesUpdated        CounselingCase[]       @relation("CounselingCaseUpdatedBy")
  counselingNotesCreated        CounselingNote[]       @relation("CounselingNoteCreatedBy")
  disciplineViolationsReported  DisciplineViolation[]  @relation("DisciplineViolationReportedBy")
  disciplineViolationsConfirmed DisciplineViolation[]  @relation("DisciplineViolationConfirmedBy")
  studentAchievementsAwarded    StudentAchievement[]   @relation("StudentAchievementAwardedBy")
  createdLetterTemplates        LetterTemplate[]       @relation("LetterTemplateCreatedBy")
  updatedLetterTemplates        LetterTemplate[]       @relation("LetterTemplateUpdatedBy")
  createdLetters                Letter[]               @relation("LetterCreatedBy")
  updatedLetters                Letter[]               @relation("LetterUpdatedBy")
  approvedLetters               Letter[]               @relation("LetterApprovedBy")
  rejectedLetters               Letter[]               @relation("LetterRejectedBy")
  letterApprovals               LetterApproval[]       @relation("LetterApprovalApprover")
  uploadedLetterAttachments     LetterAttachment[]     @relation("LetterAttachmentUploadedBy")

  locationResponsibleFor       InventoryLocation[]    @relation("LocationResponsibleUser")
  createdInventoryItems        InventoryItem[]        @relation("ItemCreatedBy")
  updatedInventoryItems        InventoryItem[]        @relation("ItemUpdatedBy")
  performedInventoryMovements  InventoryMovement[]    @relation("MovementPerformedBy")
  handledInventoryMaintenances InventoryMaintenance[] @relation("MaintenanceHandledBy")
  createdInventoryMaintenances InventoryMaintenance[] @relation("MaintenanceCreatedBy")
  borrowedInventoryLoans       InventoryLoan[]        @relation("LoanBorrowerUser")
  approvedInventoryLoans       InventoryLoan[]        @relation("LoanApprovedBy")
  rejectedInventoryLoans       InventoryLoan[]        @relation("LoanRejectedBy")
  createdInventoryLoans        InventoryLoan[]        @relation("LoanCreatedBy")

  createdLibraryBooks     LibraryBook[]        @relation("LibraryBookCreatedBy")
  updatedLibraryBooks     LibraryBook[]        @relation("LibraryBookUpdatedBy")
  libraryMemberships      LibraryMember[]      @relation("LibraryMemberUser")
  borrowedLibraryLoans    LibraryLoan[]        @relation("LibraryLoanBorrowedBy")
  returnedLibraryLoans    LibraryLoan[]        @relation("LibraryLoanReturnedBy")
  handledLibraryFines     LibraryFine[]        @relation("LibraryFineHandledBy")
  employeeProfiles        EmployeeProfile[]    @relation("EmployeeUser")
  employeeProfilesCreated EmployeeProfile[]    @relation("EmployeeCreatedBy")
  employeeProfilesUpdated EmployeeProfile[]    @relation("EmployeeUpdatedBy")
  payrollPeriodsCreated   PayrollPeriod[]      @relation("PayrollPeriodCreatedBy")
  payrollPeriodsApproved  PayrollPeriod[]      @relation("PayrollPeriodApprovedBy")
  payrollRunsApproved     PayrollRun[]         @relation("PayrollRunApprovedBy")
  payrollRunsPaid         PayrollRun[]         @relation("PayrollRunPaidBy")
  attendanceRecorded      EmployeeAttendance[] @relation("AttendanceRecordedBy")
  leavesApproved          LeaveRequest[]       @relation("LeaveApprovedBy")
  leavesRejected          LeaveRequest[]       @relation("LeaveRejectedBy")
  leavesCreated           LeaveRequest[]       @relation("LeaveCreatedBy")
  payrollApprovals        PayrollApproval[]    @relation("PayrollApprovalApprover")

  @@index([name])
  @@index([lockedUntil])
  @@index([forceChangePassword])
  @@index([lastLoginAt])
  @@index([status, deletedAt])
  @@map("users")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  email     String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  success   Boolean
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
  @@map("login_histories")
}

model Role {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       UserRole[]
  permissions RolePermission[]

  @@index([isActive])
  @@index([name])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  group       String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@index([group])
  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?  @map("actor_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SchoolProfile {
  id             String   @id @default(cuid())
  name           String
  npsn           String?
  address        String?
  phone          String?
  email          String?
  website        String?
  principalName  String?  @map("principal_name")
  logoUrl        String?  @map("logo_url")
  primaryColor   String?  @default("#14997a") @map("primary_color")
  secondaryColor String?  @default("#d4ede8") @map("secondary_color")
  accentColor    String?  @default("#f97316") @map("accent_color")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([npsn])
  @@index([name])
  @@map("school_profiles")
}

model AcademicYear {
  id                  String               @id @default(cuid())
  name                String
  startDate           DateTime             @map("start_date")
  endDate             DateTime             @map("end_date")
  isActive            Boolean              @default(false) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")
  semesters           Semester[]
  teachingAssignments TeachingAssignment[]
  invoices            Invoice[]
  ppdbPeriods         PpdbPeriod[]
  exams               Exam[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("academic_years")
}

model Semester {
  id                  String               @id @default(cuid())
  academicYearId      String               @map("academic_year_id")
  name                String
  order               Int
  startDate           DateTime             @map("start_date")
  endDate             DateTime             @map("end_date")
  isActive            Boolean              @default(false) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")
  academicYear        AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  teachingAssignments TeachingAssignment[]
  invoices            Invoice[]
  exams               Exam[]

  @@index([academicYearId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("semesters")
}

model Department {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String
  description       String?
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")
  competencies      Competency[]
  ppdbRegistrations PpdbRegistration[] @relation("PpdbDepartment")

  @@index([isActive])
  @@index([deletedAt])
  @@map("departments")
}

model Competency {
  id                String             @id @default(cuid())
  departmentId      String             @map("department_id")
  code              String             @unique
  name              String
  description       String?
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")
  department        Department         @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  classrooms        Classroom[]
  ppdbRegistrations PpdbRegistration[] @relation("PpdbCompetency")

  @@index([departmentId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("competencies")
}

model Classroom {
  id                  String               @id @default(cuid())
  competencyId        String               @map("competency_id")
  code                String               @unique
  name                String
  level               Int
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")
  competency          Competency           @relation(fields: [competencyId], references: [id], onDelete: Restrict)
  students            Student[]
  teachingAssignments TeachingAssignment[]

  @@index([competencyId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("classrooms")
}

model Room {
  id                 String              @id @default(cuid())
  code               String              @unique
  name               String
  type               String?
  capacity           Int?
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  schedules          Schedule[]
  inventoryLocations InventoryLocation[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("rooms")
}

model Subject {
  id                  String               @id @default(cuid())
  code                String               @unique
  name                String
  group               String?
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")
  teachingAssignments TeachingAssignment[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("subjects")
}

model LessonHour {
  id        String     @id @default(cuid())
  name      String
  order     Int
  startTime String     @map("start_time")
  endTime   String     @map("end_time")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  schedules Schedule[]

  @@index([order])
  @@index([isActive])
  @@index([deletedAt])
  @@map("lesson_hours")
}

model PaymentCategory {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  description   String?
  defaultAmount Int           @default(0) @map("default_amount")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")
  invoiceItems  InvoiceItem[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("payment_categories")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  PERMIT
  SICK
}

enum AssessmentType {
  DAILY
  ASSIGNMENT
  QUIZ
  MIDTERM
  FINAL
  PRACTICAL
  PROJECT
}

enum GradeStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PUBLISHED
}

model TeachingAssignment {
  id             String       @id @default(cuid())
  teacherId      String       @map("teacher_id")
  subjectId      String       @map("subject_id")
  classroomId    String       @map("classroom_id")
  academicYearId String       @map("academic_year_id")
  semesterId     String       @map("semester_id")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  teacher        Teacher      @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  classroom      Classroom    @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  semester       Semester     @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  schedules      Schedule[]
  assessments    Assessment[]

  @@unique([teacherId, subjectId, classroomId, semesterId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([classroomId])
  @@index([academicYearId])
  @@index([semesterId])
  @@index([deletedAt])
  @@map("teaching_assignments")
}

model Schedule {
  id                   String              @id @default(cuid())
  teachingAssignmentId String              @map("teaching_assignment_id")
  roomId               String              @map("room_id")
  lessonHourId         String              @map("lesson_hour_id")
  dayOfWeek            DayOfWeek           @map("day_of_week")
  isActive             Boolean             @default(true) @map("is_active")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  deletedAt            DateTime?           @map("deleted_at")
  teachingAssignment   TeachingAssignment  @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  room                 Room                @relation(fields: [roomId], references: [id], onDelete: Restrict)
  lessonHour           LessonHour          @relation(fields: [lessonHourId], references: [id], onDelete: Restrict)
  attendanceSessions   AttendanceSession[]

  @@unique([roomId, dayOfWeek, lessonHourId])
  @@unique([lessonHourId, dayOfWeek, teachingAssignmentId])
  @@index([teachingAssignmentId])
  @@index([roomId])
  @@index([lessonHourId])
  @@index([dayOfWeek])
  @@index([deletedAt])
  @@map("schedules")
}

model AttendanceSession {
  id         String             @id @default(cuid())
  scheduleId String             @map("schedule_id")
  date       DateTime           @map("date")
  topic      String?
  notes      String?
  isActive   Boolean            @default(true) @map("is_active")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  deletedAt  DateTime?          @map("deleted_at")
  schedule   Schedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  records    AttendanceRecord[]

  @@unique([scheduleId, date])
  @@index([scheduleId])
  @@index([date])
  @@index([deletedAt])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String            @id @default(cuid())
  sessionId String            @map("session_id")
  studentId String            @map("student_id")
  status    AttendanceStatus  @default(PRESENT)
  note      String?
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([sessionId, studentId])
  @@map("attendance_records")
}

model Assessment {
  id                   String             @id @default(cuid())
  teachingAssignmentId String             @map("teaching_assignment_id")
  name                 String
  type                 AssessmentType     @default(DAILY)
  maxScore             Int                @default(100) @map("max_score")
  weight               Int                @default(1)
  description          String?
  dueDate              DateTime?          @map("due_date")
  isActive             Boolean            @default(true) @map("is_active")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  deletedAt            DateTime?          @map("deleted_at")
  teachingAssignment   TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  grades               Grade[]

  @@index([teachingAssignmentId])
  @@index([deletedAt])
  @@map("assessments")
}

model Grade {
  id           String      @id @default(cuid())
  assessmentId String      @map("assessment_id")
  studentId    String      @map("student_id")
  score        Int
  status       GradeStatus @default(DRAFT)
  notes        String?
  gradedById   String?     @map("graded_by_id")
  gradedAt     DateTime?   @map("graded_at")
  approvedById String?     @map("approved_by_id")
  approvedAt   DateTime?   @map("approved_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  assessment   Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student      Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId])
  @@index([assessmentId])
  @@index([studentId])
  @@index([status])
  @@index([assessmentId, studentId])
  @@map("grades")
}

enum Gender {
  MALE
  FEMALE
}

enum PersonStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  RESIGNED
}

enum EmploymentStatus {
  PERMANENT
  CONTRACT
  HONORARY
  PROBATION
}

enum GuardianRelation {
  FATHER
  MOTHER
  GUARDIAN
  GRANDPARENT
  SIBLING
  OTHER
}

model Student {
  id                   String                @id @default(cuid())
  nis                  String                @unique
  nisn                 String?               @unique
  userId               String?               @unique @map("user_id")
  name                 String
  gender               Gender
  birthPlace           String?               @map("birth_place")
  birthDate            DateTime?             @map("birth_date")
  address              String?
  phone                String?
  email                String?               @unique
  classroomId          String?               @map("classroom_id")
  status               PersonStatus          @default(ACTIVE)
  photoUrl             String?               @map("photo_url")
  enrolledAt           DateTime?             @map("enrolled_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")
  user                 User?                 @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)
  classroom            Classroom?            @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  guardians            StudentGuardian[]
  attendanceRecords    AttendanceRecord[]
  grades               Grade[]
  invoices             Invoice[]
  ppdbRegistrations    PpdbRegistration[]    @relation("ConvertedStudent")
  internships          Internship[]
  alumni               Alumni?               @relation("StudentAlumni")
  counselingCases      CounselingCase[]
  disciplineViolations DisciplineViolation[]
  achievements         StudentAchievement[]
  letters              Letter[]
  libraryMemberships   LibraryMember[]       @relation("LibraryMemberStudent")
  examParticipants     ExamParticipant[]

  @@index([classroomId])
  @@index([status])
  @@index([deletedAt])
  @@index([name])
  @@index([userId])
  @@index([status, classroomId, deletedAt])
  @@map("students")
}

model Guardian {
  id         String            @id @default(cuid())
  userId     String?           @unique @map("user_id")
  name       String
  relation   GuardianRelation
  phone      String
  email      String?           @unique
  occupation String?
  address    String?
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  user       User?             @relation("GuardianUser", fields: [userId], references: [id], onDelete: SetNull)
  students   StudentGuardian[]
  letters    Letter[]

  @@index([name])
  @@index([userId])
  @@map("guardians")
}

model StudentGuardian {
  studentId  String   @map("student_id")
  guardianId String   @map("guardian_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian   Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
  @@index([guardianId])
  @@map("student_guardians")
}

// Phase 12.1 - BK and Discipline
enum CounselingPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CounselingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum CounselingNoteVisibility {
  PRIVATE
  COUNSELOR_ONLY
  HOMEROOM_TEACHER
  PARENT_VISIBLE
}

enum DisciplineSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DisciplineViolationStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

model CounselingCase {
  id           String             @id @default(cuid())
  studentId    String             @map("student_id")
  counselorId  String?            @map("counselor_id")
  title        String
  category     String
  priority     CounselingPriority @default(MEDIUM)
  status       CounselingStatus   @default(OPEN)
  description  String
  resolution   String?
  followUpDate DateTime?          @map("follow_up_date")
  openedAt     DateTime           @default(now()) @map("opened_at")
  closedAt     DateTime?          @map("closed_at")
  createdById  String             @map("created_by_id")
  updatedById  String?            @map("updated_by_id")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  deletedAt    DateTime?          @map("deleted_at")

  student   Student          @relation(fields: [studentId], references: [id], onDelete: Restrict)
  counselor User?            @relation("CounselingCaseCounselor", fields: [counselorId], references: [id], onDelete: SetNull)
  createdBy User             @relation("CounselingCaseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?            @relation("CounselingCaseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  notes     CounselingNote[]
  letters   Letter[]

  @@index([studentId])
  @@index([counselorId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([followUpDate])
  @@index([createdById])
  @@index([deletedAt])
  @@map("counseling_cases")
