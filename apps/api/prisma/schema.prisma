enum PpdbRegistrationStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REVISION
  ACCEPTED
  REJECTED
  CONVERTED
}

enum PpdbDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PpdbSelectionStatus {
  PENDING
  PASSED
  FAILED
}

model PpdbPeriod {
  id             String   @id @default(cuid())
  name           String
  academicYearId String?  @map("academic_year_id")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  isActive       Boolean  @default(true) @map("is_active")
  quota          Int?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  academicYear  AcademicYear?      @relation(fields: [academicYearId], references: [id])
  registrations PpdbRegistration[]

  @@index([isActive])
  @@map("ppdb_periods")
}

model PpdbRegistration {
  id                   String                 @id @default(cuid())
  registrationNumber   String                 @unique @map("registration_number")
  periodId             String                 @map("period_id")
  name                 String
  gender               Gender
  birthPlace           String?                @map("birth_place")
  birthDate            DateTime?              @map("birth_date")
  address              String?
  phone                String
  accessPinHash        String?                @map("access_pin_hash")
  email                String?
  previousSchool       String?                @map("previous_school")
  selectedDepartmentId String?                @map("selected_department_id")
  selectedCompetencyId String?                @map("selected_competency_id")
  status               PpdbRegistrationStatus @default(DRAFT)
  selectionStatus      PpdbSelectionStatus    @default(PENDING) @map("selection_status")
  verifiedAt           DateTime?              @map("verified_at")
  verifiedById         String?                @map("verified_by_id")
  convertedStudentId   String?                @map("converted_student_id")
  note                 String?
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")

  period             PpdbPeriod          @relation(fields: [periodId], references: [id])
  selectedDepartment Department?         @relation("PpdbDepartment", fields: [selectedDepartmentId], references: [id])
  selectedCompetency Competency?         @relation("PpdbCompetency", fields: [selectedCompetencyId], references: [id])
  verifiedBy         User?               @relation("PpdbVerifier", fields: [verifiedById], references: [id])
  convertedStudent   Student?            @relation("ConvertedStudent", fields: [convertedStudentId], references: [id])
  documents          PpdbDocument[]
  statusHistory      PpdbStatusHistory[]

  @@index([periodId])
  @@index([status])
  @@index([convertedStudentId])
  @@map("ppdb_registrations")
}

model PpdbDocument {
  id             String             @id @default(cuid())
  registrationId String             @map("registration_id")
  name           String
  fileUrl        String             @map("file_url")
  status         PpdbDocumentStatus @default(PENDING)
  note           String?
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  registration PpdbRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@map("ppdb_documents")
}

model PpdbStatusHistory {
  id             String                  @id @default(cuid())
  registrationId String                  @map("registration_id")
  fromStatus     PpdbRegistrationStatus? @map("from_status")
  toStatus       PpdbRegistrationStatus  @map("to_status")
  note           String?
  changedById    String?                 @map("changed_by_id")
  createdAt      DateTime                @default(now()) @map("created_at")

  registration PpdbRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  changedBy    User?            @relation("PpdbStatusChanger", fields: [changedById], references: [id])

  @@index([registrationId])
  @@map("ppdb_status_histories")
}

