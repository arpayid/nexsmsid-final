  activity     String
  obstacle     String?
  solution     String?
  status       InternshipLogStatus @default(DRAFT)
  reviewedById String?             @map("reviewed_by_id")
  reviewedAt   DateTime?           @map("reviewed_at")
  note         String?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  reviewedBy User?      @relation("InternshipLogReviewer", fields: [reviewedById], references: [id])

  @@index([internshipId])
  @@index([status])
  @@map("internship_logs")
}

model InternshipScore {
  id              String   @id @default(cuid())
  internshipId    String   @unique @map("internship_id")
  disciplineScore Int      @map("discipline_score")
  skillScore      Int      @map("skill_score")
  attitudeScore   Int      @map("attitude_score")
  reportScore     Int      @map("report_score")
  finalScore      Decimal  @map("final_score")
  assessedById    String?  @map("assessed_by_id")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  assessedBy User?      @relation("InternshipScoreAssessor", fields: [assessedById], references: [id])

  @@index([assessedById])
  @@map("internship_scores")
}

model Alumni {
  id              String       @id @default(cuid())
  studentId       String?      @unique @map("student_id")
  nis             String?
  name            String
  graduationYear  Int          @map("graduation_year")
  phone           String?
  email           String?
  address         String?
  status          AlumniStatus @default(UNKNOWN)
  currentCompany  String?      @map("current_company")
  currentPosition String?      @map("current_position")
  university      String?
  businessName    String?      @map("business_name")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  student         Student?         @relation("StudentAlumni", fields: [studentId], references: [id])
  jobApplications JobApplication[]
  tracerStudies   TracerStudy[]

  @@index([status])
  @@index([graduationYear])
  @@index([deletedAt])
  @@index([name])
  @@map("alumni")
}

model JobVacancy {
  id                String    @id @default(cuid())
  industryPartnerId String?   @map("industry_partner_id")
  title             String
  companyName       String    @map("company_name")
  description       String
  qualification     String?
  location          String?
  employmentType    String?   @map("employment_type")
  salaryRange       String?   @map("salary_range")
  deadline          DateTime?
  status            JobStatus @default(DRAFT)
  publishedAt       DateTime? @map("published_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  industryPartner IndustryPartner? @relation(fields: [industryPartnerId], references: [id])
  applications    JobApplication[]

  @@index([industryPartnerId])
  @@index([status])
  @@index([deletedAt])
  @@index([deadline])
  @@map("job_vacancies")
}

model JobApplication {
  id             String               @id @default(cuid())
  jobVacancyId   String               @map("job_vacancy_id")
  alumniId       String?              @map("alumni_id")
  applicantName  String               @map("applicant_name")
  applicantEmail String?              @map("applicant_email")
  applicantPhone String?              @map("applicant_phone")
  cvUrl          String?              @map("cv_url")
  status         JobApplicationStatus @default(SUBMITTED)
  note           String?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  jobVacancy JobVacancy @relation(fields: [jobVacancyId], references: [id], onDelete: Cascade)
  alumni     Alumni?    @relation(fields: [alumniId], references: [id])

  @@unique([jobVacancyId, applicantEmail])
  @@index([jobVacancyId])
  @@index([alumniId])
  @@index([status])
  @@map("job_applications")
}

model TracerStudy {
  id           String       @id @default(cuid())
  alumniId     String       @map("alumni_id")
  year         Int
  status       AlumniStatus @default(UNKNOWN)
  companyName  String?      @map("company_name")
  position     String?
  university   String?
  major        String?
  businessName String?      @map("business_name")
  incomeRange  String?      @map("income_range")
  feedback     String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  alumni Alumni @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([alumniId])
  @@index([year])
  @@index([status])
  @@map("tracer_studies")
}

// Phase 10 - Communication, Notifications, Reports
enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementAudience {
  ALL
  STUDENTS
  PARENTS
  TEACHERS
  STAFF
}

enum MessageStatus {
  SENT
  READ
  DELETED
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum ReportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ReportFormat {
  CSV
  XLSX
  PDF
  JSON
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  content     String
  audience    AnnouncementAudience @default(ALL)
  status      AnnouncementStatus   @default(DRAFT)
  publishedAt DateTime?            @map("published_at")
  archivedAt  DateTime?            @map("archived_at")
  createdById String?              @map("created_by_id")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")

  createdBy  User?                   @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)
  recipients AnnouncementRecipient[]

  @@index([audience])
  @@index([status])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("announcements")
}

model AnnouncementRecipient {
  id             String    @id @default(cuid())
  announcementId String    @map("announcement_id")
  userId         String?   @map("user_id")
  name           String?
  email          String?
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([announcementId])
  @@index([userId])
  @@map("announcement_recipients")
}

model InternalMessage {
  id          String        @id @default(cuid())
  senderId    String        @map("sender_id")
  recipientId String        @map("recipient_id")
  subject     String
  body        String
  status      MessageStatus @default(SENT)
  readAt      DateTime?     @map("read_at")
  readById    String?       @map("read_by_id")
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  sender    User  @relation("InternalMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User  @relation("InternalMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  readBy    User? @relation("InternalMessageReader", fields: [readById], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([recipientId])
  @@index([status])
  @@index([deletedAt])
  @@map("internal_messages")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  title     String
  body      String
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(UNREAD)
  readAt    DateTime?           @map("read_at")
  metadata  Json?
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([channel])
  @@map("notifications")
}

model NotificationTemplate {
  id          String              @id @default(cuid())
  code        String              @unique
  name        String
  channel     NotificationChannel @default(IN_APP)
  subject     String?
  body        String
  isActive    Boolean             @default(true) @map("is_active")
  createdById String?             @map("created_by_id")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  createdBy User? @relation("NotificationTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([channel])
  @@index([isActive])
  @@index([deletedAt])
  @@map("notification_templates")
}

model ReportJob {
  id            String          @id @default(cuid())
  type          String
  title         String
  format        ReportFormat    @default(CSV)
  status        ReportJobStatus @default(PENDING)
  parameters    Json?
  resultUrl     String?         @map("result_url")
  errorMessage  String?         @map("error_message")
  requestedById String?         @map("requested_by_id")
  queuedAt      DateTime        @default(now()) @map("queued_at")
  startedAt     DateTime?       @map("started_at")
  completedAt   DateTime?       @map("completed_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  requestedBy     User?           @relation("ReportJobRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  exportHistories ExportHistory[]

  @@index([type])
  @@index([status])
  @@index([requestedById])
  @@map("report_jobs")
}

model ExportHistory {
  id            String       @id @default(cuid())
  reportJobId   String?      @map("report_job_id")
  entity        String
  format        ReportFormat @default(CSV)
  fileName      String       @map("file_name")
  fileUrl       String?      @map("file_url")
  rowCount      Int?         @map("row_count")
  requestedById String?      @map("requested_by_id")
  createdAt     DateTime     @default(now()) @map("created_at")

  reportJob   ReportJob? @relation(fields: [reportJobId], references: [id], onDelete: SetNull)
  requestedBy User?      @relation("ExportHistoryRequester", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([reportJobId])
  @@index([entity])
  @@index([requestedById])
  @@map("export_histories")
}

// Phase 12.3 - Inventory / Sarpras

enum InventoryAssetStatus {
  ACTIVE
  INACTIVE
  LOST
  DISPOSED
  BORROWED
  MAINTENANCE
}

enum InventoryAssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
  HEAVILY_DAMAGED
}

enum InventoryItemType {
  ASSET
  CONSUMABLE
}

enum InventoryMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
  BORROW
  RETURN
  DISPOSAL
}

enum InventoryMaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InventoryLoanStatus {
  REQUESTED
  APPROVED
  BORROWED
  RETURNED
  REJECTED
  CANCELLED
  OVERDUE
}

model InventoryCategory {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  items InventoryItem[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("inventory_categories")
}

model InventoryLocation {
  id                String    @id @default(cuid())
  code              String    @unique
  name              String
  description       String?
  roomId            String?   @map("room_id")
  responsibleUserId String?   @map("responsible_user_id")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  room            Room?               @relation(fields: [roomId], references: [id], onDelete: SetNull)
  responsibleUser User?               @relation("LocationResponsibleUser", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  items           InventoryItem[]
  movementsFrom   InventoryMovement[] @relation("MovementFromLocation")
  movementsTo     InventoryMovement[] @relation("MovementToLocation")

  @@index([roomId])
  @@index([responsibleUserId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("inventory_locations")
}

model InventoryItem {
  id            String                  @id @default(cuid())
  categoryId    String                  @map("category_id")
  locationId    String?                 @map("location_id")
  code          String                  @unique
  name          String
  type          InventoryItemType       @default(ASSET)
  description   String?
  brand         String?
  model         String?
  unit          String                  @default("unit")
  quantity      Int                     @default(1)
  minStock      Int?                    @map("min_stock")
  purchaseDate  DateTime?               @map("purchase_date")
  purchasePrice Decimal?                @map("purchase_price") @db.Decimal(12, 2)
  supplier      String?
  status        InventoryAssetStatus    @default(ACTIVE)
  condition     InventoryAssetCondition @default(GOOD)
  qrCode        String?                 @map("qr_code")
  barcode       String?
  createdById   String                  @map("created_by_id")
  updatedById   String?                 @map("updated_by_id")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  deletedAt     DateTime?               @map("deleted_at")

  category  InventoryCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  location  InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdBy User               @relation("ItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?              @relation("ItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  movements    InventoryMovement[]
  maintenances InventoryMaintenance[]
  loans        InventoryLoan[]

  @@index([categoryId])
  @@index([locationId])
  @@index([code])
  @@index([name])
  @@index([type])
  @@index([status])
  @@index([condition])
  @@index([createdById])
  @@index([deletedAt])
  @@map("inventory_items")
}

model InventoryMovement {
  id             String                @id @default(cuid())
  itemId         String                @map("item_id")
  type           InventoryMovementType
  quantity       Int                   @default(1)
  fromLocationId String?               @map("from_location_id")
  toLocationId   String?               @map("to_location_id")
  note           String?
  referenceType  String?               @map("reference_type")
  referenceId    String?               @map("reference_id")
  performedById  String                @map("performed_by_id")
  performedAt    DateTime              @default(now()) @map("performed_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  item         InventoryItem      @relation(fields: [itemId], references: [id], onDelete: Restrict)
  fromLocation InventoryLocation? @relation("MovementFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation   InventoryLocation? @relation("MovementToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  performedBy  User               @relation("MovementPerformedBy", fields: [performedById], references: [id], onDelete: Restrict)

  @@index([itemId])
  @@index([type])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([performedById])
  @@index([performedAt])
  @@map("inventory_movements")
}

model InventoryMaintenance {
  id          String                     @id @default(cuid())
  itemId      String                     @map("item_id")
  title       String
  description String?
  status      InventoryMaintenanceStatus @default(SCHEDULED)
  scheduledAt DateTime?                  @map("scheduled_at")
  startedAt   DateTime?                  @map("started_at")
  completedAt DateTime?                  @map("completed_at")
  cost        Decimal?
  vendor      String?
  handledById String?                    @map("handled_by_id")
  createdById String                     @map("created_by_id")
  createdAt   DateTime                   @default(now()) @map("created_at")
  updatedAt   DateTime                   @updatedAt @map("updated_at")
  deletedAt   DateTime?                  @map("deleted_at")

  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  handledBy User?         @relation("MaintenanceHandledBy", fields: [handledById], references: [id], onDelete: SetNull)
  createdBy User          @relation("MaintenanceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([itemId])
  @@index([status])
  @@index([handledById])
  @@index([createdById])
  @@index([deletedAt])
  @@map("inventory_maintenances")
}

model InventoryLoan {
  id             String              @id @default(cuid())
  itemId         String              @map("item_id")
  borrowerUserId String?             @map("borrower_user_id")
  borrowerName   String              @map("borrower_name")
  borrowerType   String              @map("borrower_type")
  quantity       Int                 @default(1)
  purpose        String
  status         InventoryLoanStatus @default(REQUESTED)
  requestedAt    DateTime            @default(now()) @map("requested_at")
  approvedAt     DateTime?           @map("approved_at")
  borrowedAt     DateTime?           @map("borrowed_at")
  dueAt          DateTime?           @map("due_at")
  returnedAt     DateTime?           @map("returned_at")
  rejectedAt     DateTime?           @map("rejected_at")
  cancelledAt    DateTime?           @map("cancelled_at")
  approvedById   String?             @map("approved_by_id")
  rejectedById   String?             @map("rejected_by_id")
  createdById    String              @map("created_by_id")
  note           String?
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt      DateTime?           @map("deleted_at")

  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  borrowerUser User?         @relation("LoanBorrowerUser", fields: [borrowerUserId], references: [id], onDelete: SetNull)
  approvedBy   User?         @relation("LoanApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy   User?         @relation("LoanRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  createdBy    User          @relation("LoanCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([itemId])
  @@index([borrowerUserId])
  @@index([status])
  @@index([dueAt])
  @@index([createdById])
  @@index([deletedAt])
  @@map("inventory_loans")
}

// ==================================================
// PHASE 12.4: LIBRARY MANAGEMENT
// ==================================================

enum LibraryBookStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum LibraryCopyStatus {
  AVAILABLE
  BORROWED
  RESERVED
  LOST
  DAMAGED
  MAINTENANCE
  INACTIVE
}

enum LibraryMemberType {
  STUDENT
  TEACHER
  STAFF
  EXTERNAL
}

enum LibraryMemberStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum LibraryLoanStatus {
  BORROWED
  RETURNED
  OVERDUE
  LOST
  CANCELLED
}

enum LibraryReservationStatus {
  PENDING
  READY
  BORROWED
  CANCELLED
  EXPIRED
}

enum LibraryFineStatus {
  UNPAID
  PAID
  WAIVED
  CANCELLED
}

model LibraryCategory {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  books LibraryBook[]

  @@index([isActive])
  @@index([name])
  @@index([deletedAt])
  @@map("library_categories")
}

model LibraryShelf {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  location    String?
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  books LibraryBook[]

  @@index([isActive])
  @@index([name])
  @@index([location])
  @@index([deletedAt])
  @@map("library_shelves")
}

model LibraryBook {
  id              String            @id @default(cuid())
  categoryId      String            @map("category_id")
  shelfId         String?           @map("shelf_id")
  isbn            String?
  code            String            @unique
  title           String
  subtitle        String?
  author          String
  publisher       String?
  publicationYear Int?              @map("publication_year")
  language        String?
  edition         String?
  description     String?
  coverUrl        String?           @map("cover_url")
  status          LibraryBookStatus @default(ACTIVE)
  createdById     String            @map("created_by_id")
  updatedById     String?           @map("updated_by_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  category     LibraryCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  shelf        LibraryShelf?        @relation(fields: [shelfId], references: [id], onDelete: SetNull)
  createdBy    User                 @relation("LibraryBookCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy    User?                @relation("LibraryBookUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  copies       LibraryBookCopy[]
  reservations LibraryReservation[]

  @@index([categoryId])
  @@index([shelfId])
  @@index([code])
  @@index([isbn])
  @@index([title])
  @@index([author])
  @@index([status])
  @@index([deletedAt])
  @@map("library_books")
}

model LibraryBookCopy {
  id                String                   @id @default(cuid())
  bookId            String                   @map("book_id")
  copyCode          String                   @unique @map("copy_code")
  barcode           String?
  qrCode            String?                  @map("qr_code")
  acquisitionDate   DateTime?                @map("acquisition_date")
  acquisitionSource String?                  @map("acquisition_source")
  price             Decimal?                 @db.Decimal(12, 2)
  status            LibraryCopyStatus        @default(AVAILABLE)
  condition         InventoryAssetCondition?
  note              String?
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  deletedAt         DateTime?                @map("deleted_at")

  book  LibraryBook   @relation(fields: [bookId], references: [id], onDelete: Restrict)
  loans LibraryLoan[]

  @@index([bookId])
  @@index([copyCode])
  @@index([barcode])
  @@index([status])
  @@index([deletedAt])
  @@map("library_book_copies")
}

model LibraryMember {
  id              String              @id @default(cuid())
  memberCode      String              @unique @map("member_code")
  type            LibraryMemberType
  status          LibraryMemberStatus @default(ACTIVE)
  userId          String?             @map("user_id")
  studentId       String?             @map("student_id")
  teacherId       String?             @map("teacher_id")
  staffId         String?             @map("staff_id")
  externalName    String?             @map("external_name")
  externalContact String?             @map("external_contact")
  joinedAt        DateTime            @default(now()) @map("joined_at")
  expiredAt       DateTime?           @map("expired_at")
  maxLoan         Int                 @default(3) @map("max_loan")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  user         User?                @relation("LibraryMemberUser", fields: [userId], references: [id], onDelete: SetNull)
  student      Student?             @relation("LibraryMemberStudent", fields: [studentId], references: [id], onDelete: SetNull)
  teacher      Teacher?             @relation("LibraryMemberTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  staff        Staff?               @relation("LibraryMemberStaff", fields: [staffId], references: [id], onDelete: SetNull)
  loans        LibraryLoan[]
  reservations LibraryReservation[]
  fines        LibraryFine[]

  @@index([memberCode])
  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([studentId])
  @@index([teacherId])
