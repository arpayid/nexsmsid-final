// Phase 12.2 - Letter Management / Surat Menyurat
enum LetterDirection {
  INCOMING
  OUTGOING
  INTERNAL
}

enum LetterStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ISSUED
  ARCHIVED
  CANCELLED
}

enum LetterPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum LetterRecipientType {
  STUDENT
  GUARDIAN
  TEACHER
  STAFF
  USER
  EXTERNAL
}

enum LetterTemplateStatus {
  ACTIVE
  INACTIVE
}

enum LetterApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model LetterTemplate {
  id               String               @id @default(cuid())
  code             String               @unique
  name             String
  description      String?
  category         String
  status           LetterTemplateStatus @default(ACTIVE)
  subjectTemplate  String               @map("subject_template")
  bodyTemplate     String               @map("body_template")
  variables        Json?
  requiresApproval Boolean              @default(false) @map("requires_approval")
  createdById      String               @map("created_by_id")
  updatedById      String?              @map("updated_by_id")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  deletedAt        DateTime?            @map("deleted_at")

  createdBy User     @relation("LetterTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?    @relation("LetterTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  letters   Letter[]

  @@index([code])
  @@index([category])
  @@index([status])
  @@index([createdById])
  @@index([deletedAt])
  @@map("letter_templates")
}

model Letter {
  id                           String              @id @default(cuid())
  templateId                   String?             @map("template_id")
  letterNumber                 String?             @unique @map("letter_number")
  subject                      String
  body                         String
  direction                    LetterDirection     @default(OUTGOING)
  status                       LetterStatus        @default(DRAFT)
  priority                     LetterPriority      @default(NORMAL)
  category                     String
  recipientType                LetterRecipientType @map("recipient_type")
  recipientName                String              @map("recipient_name")
  recipientEmail               String?             @map("recipient_email")
  recipientAddress             String?             @map("recipient_address")
  studentId                    String?             @map("student_id")
  guardianId                   String?             @map("guardian_id")
  teacherId                    String?             @map("teacher_id")
  staffId                      String?             @map("staff_id")
  relatedCounselingCaseId      String?             @map("related_counseling_case_id")
  relatedDisciplineViolationId String?             @map("related_discipline_violation_id")
  issuedAt                     DateTime?           @map("issued_at")
  submittedAt                  DateTime?           @map("submitted_at")
  approvedAt                   DateTime?           @map("approved_at")
  rejectedAt                   DateTime?           @map("rejected_at")
  archivedAt                   DateTime?           @map("archived_at")
  cancelledAt                  DateTime?           @map("cancelled_at")
  createdById                  String              @map("created_by_id")
  updatedById                  String?             @map("updated_by_id")
  approvedById                 String?             @map("approved_by_id")
  rejectedById                 String?             @map("rejected_by_id")
  rejectionReason              String?             @map("rejection_reason")
  createdAt                    DateTime            @default(now()) @map("created_at")
  updatedAt                    DateTime            @updatedAt @map("updated_at")
  deletedAt                    DateTime?           @map("deleted_at")

  template                   LetterTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  student                    Student?             @relation(fields: [studentId], references: [id], onDelete: SetNull)
  guardian                   Guardian?            @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  teacher                    Teacher?             @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  staff                      Staff?               @relation(fields: [staffId], references: [id], onDelete: SetNull)
  relatedCounselingCase      CounselingCase?      @relation(fields: [relatedCounselingCaseId], references: [id], onDelete: SetNull)
  relatedDisciplineViolation DisciplineViolation? @relation(fields: [relatedDisciplineViolationId], references: [id], onDelete: SetNull)
  createdBy                  User                 @relation("LetterCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy                  User?                @relation("LetterUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  approvedBy                 User?                @relation("LetterApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy                 User?                @relation("LetterRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  approvals                  LetterApproval[]
  attachments                LetterAttachment[]

  @@index([letterNumber])
  @@index([status])
  @@index([direction])
  @@index([category])
  @@index([recipientType])
  @@index([studentId])
  @@index([guardianId])
  @@index([teacherId])
  @@index([staffId])
  @@index([createdById])
  @@index([approvedById])
  @@index([issuedAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("letters")
}

model LetterApproval {
  id         String               @id @default(cuid())
  letterId   String               @map("letter_id")
  approverId String               @map("approver_id")
  status     LetterApprovalStatus @default(PENDING)
  note       String?
  approvedAt DateTime?            @map("approved_at")
  rejectedAt DateTime?            @map("rejected_at")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  letter   Letter @relation(fields: [letterId], references: [id], onDelete: Cascade)
  approver User   @relation("LetterApprovalApprover", fields: [approverId], references: [id], onDelete: Restrict)

  @@index([letterId])
  @@index([approverId])
  @@index([status])
  @@index([createdAt])
  @@map("letter_approvals")
}

model LetterAttachment {
  id           String   @id @default(cuid())
  letterId     String   @map("letter_id")
  filename     String
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  path         String
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  letter     Letter @relation(fields: [letterId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("LetterAttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([letterId])
  @@index([uploadedById])
  @@index([createdAt])
  @@map("letter_attachments")
}

model LetterNumberSequence {
  id            String   @id @default(cuid())
  category      String
  year          Int
  month         Int?
  currentNumber Int      @default(0) @map("current_number")
  format        String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([category, year, month])
  @@index([category, year])
  @@map("letter_number_sequences")
}

// Phase 8 - Finance
enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  QRIS
  OTHER
}

enum ExpenseStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique @map("invoice_number")
  studentId      String        @map("student_id")
  academicYearId String?       @map("academic_year_id")
  semesterId     String?       @map("semester_id")
  issueDate      DateTime      @map("issue_date")
  dueDate        DateTime?     @map("due_date")
  subtotal       Decimal       @default(0) @map("subtotal") @db.Decimal(12, 2)
  discount       Decimal       @default(0) @map("discount") @db.Decimal(12, 2)
  penalty        Decimal       @default(0) @map("penalty") @db.Decimal(12, 2)
  total          Decimal       @default(0) @map("total") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status         InvoiceStatus @default(DRAFT)
  note           String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  student      Student       @relation(fields: [studentId], references: [id])
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])
  semester     Semester?     @relation(fields: [semesterId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]

  @@index([studentId])
  @@index([status])
  @@index([deletedAt])
  @@index([status, studentId, dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id                String   @id @default(cuid())
  invoiceId         String   @map("invoice_id")
  paymentCategoryId String?  @map("payment_category_id")
  name              String
  quantity          Int      @default(1)
  unitPrice         Decimal  @map("unit_price")
  total             Decimal  @map("total")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  invoice         Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentCategory PaymentCategory? @relation(fields: [paymentCategoryId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id            String        @id @default(cuid())
  paymentNumber String        @unique @map("payment_number")
  invoiceId     String        @map("invoice_id")
  amount        Decimal       @map("amount")
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime      @default(now()) @map("paid_at")
  verifiedAt    DateTime?     @map("verified_at")
  verifiedById  String?       @map("verified_by_id")
  proofUrl      String?       @map("proof_url")
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  verifiedBy User?   @relation("VerifiedPayments", fields: [verifiedById], references: [id])

  @@index([invoiceId])
  @@index([status])
  @@index([status, invoiceId])
  @@map("payments")
}

model Expense {
  id            String        @id @default(cuid())
  expenseNumber String        @unique @map("expense_number")
  title         String
  category      String
  amount        Decimal       @map("amount") @db.Decimal(12, 2)
  date          DateTime      @default(now()) @map("date")
  status        ExpenseStatus @default(DRAFT)
  approvedById  String?       @map("approved_by_id")
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  approvedBy User? @relation("ApprovedExpenses", fields: [approvedById], references: [id])

  @@index([status])
  @@index([deletedAt])
  @@map("expenses")
}

