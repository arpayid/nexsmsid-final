  @@index([employeeCode])
  @@index([userId])
  @@index([teacherId])
  @@index([staffId])
  @@index([positionId])
  @@index([status])
  @@index([employmentType])
  @@index([deletedAt])
  @@map("hr_employee_profiles")
}

model PayrollComponent {
  id                String                          @id @default(cuid())
  code              String                          @unique
  name              String
  type              PayrollComponentType
  calculationType   PayrollComponentCalculationType @default(FIXED) @map("calculation_type")
  defaultAmount     Decimal                         @default(0) @map("default_amount") @db.Decimal(12, 2)
  defaultPercentage Decimal?                        @map("default_percentage") @db.Decimal(5, 2)
  isTaxable         Boolean                         @default(false) @map("is_taxable")
  isActive          Boolean                         @default(true) @map("is_active")
  description       String?
  createdAt         DateTime                        @default(now()) @map("created_at")
  updatedAt         DateTime                        @updatedAt @map("updated_at")
  deletedAt         DateTime?                       @map("deleted_at")

  employeeSalaryComponents EmployeeSalaryComponent[]
  payrollRunItems          PayrollRunItem[]

  @@index([code])
  @@index([type])
  @@index([isActive])
  @@index([deletedAt])
  @@map("payroll_components")
}

model EmployeeSalaryComponent {
  id            String    @id @default(cuid())
  employeeId    String    @map("employee_id")
  componentId   String    @map("component_id")
  amount        Decimal?  @db.Decimal(12, 2)
  percentage    Decimal?  @db.Decimal(5, 2)
  isActive      Boolean   @default(true) @map("is_active")
  effectiveFrom DateTime? @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  employee  EmployeeProfile  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  component PayrollComponent @relation(fields: [componentId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([componentId])
  @@index([isActive])
  @@index([effectiveFrom])
  @@index([effectiveTo])
  @@index([deletedAt])
  @@map("payroll_employee_salary_components")
}

model PayrollPeriod {
  id           String              @id @default(cuid())
  code         String              @unique
  name         String
  month        Int
  year         Int
  startDate    DateTime            @map("start_date")
  endDate      DateTime            @map("end_date")
  paymentDate  DateTime?           @map("payment_date")
  status       PayrollPeriodStatus @default(DRAFT)
  createdById  String              @map("created_by_id")
  approvedById String?             @map("approved_by_id")
  approvedAt   DateTime?           @map("approved_at")
  closedAt     DateTime?           @map("closed_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  deletedAt    DateTime?           @map("deleted_at")

  createdBy  User  @relation("PayrollPeriodCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy User? @relation("PayrollPeriodApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  runs      PayrollRun[]
  approvals PayrollApproval[]

  @@index([code])
  @@index([month])
  @@index([year])
  @@index([status])
  @@index([deletedAt])
  @@map("payroll_periods")
}

model PayrollRun {
  id              String           @id @default(cuid())
  periodId        String           @map("period_id")
  employeeId      String           @map("employee_id")
  status          PayrollRunStatus @default(DRAFT)
  grossAmount     Decimal          @default(0) @map("gross_amount") @db.Decimal(12, 2)
  totalEarnings   Decimal          @default(0) @map("total_earnings") @db.Decimal(12, 2)
  totalDeductions Decimal          @default(0) @map("total_deductions") @db.Decimal(12, 2)
  netAmount       Decimal          @default(0) @map("net_amount") @db.Decimal(12, 2)
  calculatedAt    DateTime?        @map("calculated_at")
  approvedAt      DateTime?        @map("approved_at")
  paidAt          DateTime?        @map("paid_at")
  approvedById    String?          @map("approved_by_id")
  paidById        String?          @map("paid_by_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  period     PayrollPeriod   @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  approvedBy User?           @relation("PayrollRunApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  paidBy     User?           @relation("PayrollRunPaidBy", fields: [paidById], references: [id], onDelete: SetNull)

  items   PayrollRunItem[]
  payslip Payslip?

  @@unique([periodId, employeeId])
  @@index([periodId])
  @@index([employeeId])
  @@index([status])
  @@index([deletedAt])
  @@map("payroll_runs")
}

model PayrollRunItem {
  id              String                          @id @default(cuid())
  payrollRunId    String                          @map("payroll_run_id")
  componentId     String?                         @map("component_id")
  name            String
  type            PayrollComponentType
  calculationType PayrollComponentCalculationType @map("calculation_type")
  amount          Decimal                         @db.Decimal(12, 2)
  note            String?
  createdAt       DateTime                        @default(now()) @map("created_at")

  payrollRun PayrollRun        @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  component  PayrollComponent? @relation(fields: [componentId], references: [id], onDelete: SetNull)

  @@index([payrollRunId])
  @@index([componentId])
  @@map("payroll_run_items")
}

model Payslip {
  id               String                @id @default(cuid())
  payrollRunId     String                @unique @map("payroll_run_id")
  payslipNumber    String                @unique @map("payslip_number")
  basicSalary      Decimal               @default(0) @map("basic_salary") @db.Decimal(12, 2)
  allowances       Decimal               @default(0) @map("allowances") @db.Decimal(12, 2)
  deductions       Decimal               @default(0) @map("deductions") @db.Decimal(12, 2)
  netPay           Decimal               @default(0) @map("net_pay") @db.Decimal(12, 2)
  status           PayslipStatus         @default(DRAFT)
  issuedAt         DateTime?             @map("issued_at")
  paidAt           DateTime?             @map("paid_at")
  paymentMethod    PayrollPaymentMethod? @map("payment_method")
  paymentReference String?               @map("payment_reference")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  deletedAt        DateTime?             @map("deleted_at")

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@index([payslipNumber])
  @@index([payrollRunId])
  @@index([status])
  @@index([deletedAt])
  @@map("payroll_payslips")
}

model EmployeeAttendance {
  id           String                   @id @default(cuid())
  employeeId   String                   @map("employee_id")
  date         DateTime                 @db.Date
  status       EmployeeAttendanceStatus
  checkInAt    DateTime?                @map("check_in_at")
  checkOutAt   DateTime?                @map("check_out_at")
