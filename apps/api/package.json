{
  "name": "@nexsmsid/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @nexsmsid/types build && pnpm prisma:generate && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "test": "pnpm --filter @nexsmsid/types build && vitest run",
    "test:watch": "vitest",
    "prisma": "DATABASE_URL=${DATABASE_URL:-postgresql://nexsmsid:nexsmsid@localhost:5432/nexsmsid?schema=public} prisma",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://nexsmsid:nexsmsid@localhost:5432/nexsmsid?schema=public} prisma generate --schema prisma/schema.prisma",
    "start": "node dist/main.js",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.26",
    "@nexsmsid/types": "workspace:*",
    "@prisma/client": "^6.19.3",
    "@sentry/nestjs": "^10.59.0",
    "@sentry/profiling-node": "^10.59.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.11",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^1.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/node": "^22.18.6",
    "@vitest/coverage-v8": "^4.1.8",
    "prisma": "^6.19.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
