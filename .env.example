# --- General ---
NODE_ENV=development
API_PORT=4000
API_PREFIX=api/v1
WEB_ORIGIN=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# --- Multi-Tenant (Future) ---
# Set to "single" for current single-school mode.
# Future: "multi" for multi-tenant SaaS mode.
TENANT_MODE=single

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://nexsmsid:nexsmsid@localhost:5432/nexsmsid?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Authentication ---
# Generate production secrets using: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-with-strong-access-secret-minimum-64-chars
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-minimum-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Rate Limiting ---
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# --- Storage ---
STORAGE_PATH=./storage
REPORT_STORAGE_PATH=./storage/reports

# --- Logging ---
# Levels: error, warn, log, debug, verbose
LOG_LEVEL=log

# --- Seed (Development Only) ---
# WARNING: Override these in production!
SEED_SUPER_ADMIN_EMAIL=superadmin@nexsmsid.dev
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_NAME="Super Admin NexSMSID"

# --- SMTP / Email ---
# Uncomment to enable email sending for notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=noreply@nexsmsid.dev

# --- WhatsApp Notification ---
# Uncomment to enable WhatsApp notifications via Fonnte API
# WA_API_KEY=your-fonnte-api-key
# WA_API_URL=https://api.fonnte.com/send

# --- Web Frontend ---
NEXT_PUBLIC_API_URL=/api/v1
API_INTERNAL_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
WEB_PORT=3000

# --- Public CAPTCHA (Cloudflare Turnstile) ---
# Required when NODE_ENV=production (validated in apps/api/src/config/env.validation.ts).
# Obtain production keys from: https://dash.cloudflare.com/?to=/:account/turnstile
#
# Test keys (always pass — dev/CI only):
#   Site:   1x00000000000000000000AA
#   Secret: 1x0000000000000000000000000000000AA
#
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- PPDB legacy PIN grace (ISO-8601); after this date legacy records must set PIN ---
# PPDB_LEGACY_PIN_GRACE_END=2026-07-15T00:00:00.000Z
# PPDB_AUTO_PROVISION_STUDENT_ACCOUNT=true
# PPDB_PROVISION_EMAIL_REQUIRED=true
# PPDB_PROVISION_EMAIL_DOMAIN=sekolah.sch.id
