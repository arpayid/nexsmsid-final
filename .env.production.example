# NexSMSID V4 — Production / Staging Pilot (Docker)
#
# Usage:
#   cp .env.production.example .env.production
#   # Edit values below (JWT secrets, domain/IP, passwords)
#   pnpm docker:prod:build
#   pnpm docker:prod:up
#
# File .env.production is git-ignored. Do NOT commit secrets.
# Docker Compose reads this via --env-file (see package.json scripts).

# --- Runtime ---
NODE_ENV=production

# --- Public URL (must match how users open the app in browser) ---
# Production pelanggan (HTTPS + domain):
WEB_ORIGIN=https://sms.sekolah-contoh.sch.id
CORS_ORIGIN=https://sms.sekolah-contoh.sch.id
# Staging via IP tanpa HTTPS (ganti host ke IP server):
# WEB_ORIGIN=http://203.0.113.10
# CORS_ORIGIN=http://203.0.113.10

# --- PostgreSQL (docker-compose.prod.yml service: postgres) ---
POSTGRES_USER=nexsmsid
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=nexsmsid

# Host MUST be service name `postgres` inside Docker network
DATABASE_URL=postgresql://nexsmsid:replace-with-strong-postgres-password@postgres:5432/nexsmsid?schema=public

# --- Redis (docker-compose.prod.yml service: redis) ---
REDIS_URL=redis://redis:6379

# --- JWT (generate: openssl rand -base64 64) ---
# Min 64 chars each; must differ from each other
JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-64-chars-minimum-for-access-token
JWT_REFRESH_SECRET=replace-with-openssl-rand-base64-64-chars-minimum-for-refresh-token
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- API ---
API_PORT=4000
API_PREFIX=api/v1
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
LOG_LEVEL=log

# --- Web (built into Docker image + runtime) ---
# Relative path when behind nginx proxy:
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_APP_URL=https://sms.sekolah-contoh.sch.id
WEB_PORT=3000

# --- Cloudflare Turnstile (REQUIRED in production) ---
# Production keys: https://dash.cloudflare.com/?to=/:account/turnstile
#
# Staging pilot only — test keys (always pass):
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- Storage (inside API container) ---
STORAGE_PATH=/app/storage
REPORT_STORAGE_PATH=/app/storage/reports

# --- Seed (first deploy only — do NOT use default password in real production) ---
# SEED_SUPER_ADMIN_EMAIL=superadmin@nexsmsid.dev
# SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
# SEED_SUPER_ADMIN_NAME="Super Admin NexSMSID"

# --- Optional ---
# PPDB_LEGACY_PIN_GRACE_END=2026-07-15T00:00:00.000Z
# SMTP_HOST=
# SMTP_PORT=587
