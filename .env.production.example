# NexSMSID V4 — Production / Staging Pilot (Docker)
#
# Usage:
#   Auto-generate: bash scripts/generate-prod-env.sh [domain]
#   Manual: cp .env.production.example .env.production
#   Validate: bash scripts/validate-prod-env.sh
#
# .env.production is git-ignored. Do NOT commit secrets.

# --- Runtime ---
NODE_ENV=production

# --- Domain (untuk HTTPS otomatis via nginx entrypoint) ---
# Set untuk mengaktifkan HTTPS self-signed + redirect HTTP→HTTPS
# DOMAIN=sms.sekolah-contoh.sch.id

# --- Public URL ---
WEB_ORIGIN=https://sms.sekolah-contoh.sch.id
CORS_ORIGIN=https://sms.sekolah-contoh.sch.id
# Staging via IP (ganti ke IP server):
# WEB_ORIGIN=http://203.0.113.10
# CORS_ORIGIN=http://203.0.113.10

# --- PostgreSQL ---
POSTGRES_USER=nexsmsid
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=nexsmsid
DATABASE_URL=postgresql://nexsmsid:replace-with-strong-postgres-password@postgres:5432/nexsmsid?schema=public

# --- Redis ---
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# --- JWT (generate: openssl rand -base64 64) ---
JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-64-chars-minimum-for-access-token
JWT_REFRESH_SECRET=replace-with-openssl-rand-base64-64-chars-minimum-for-refresh-token
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- API ---
API_PORT=4000
API_PREFIX=api/v1
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
LOG_LEVEL=warn

# --- Web ---
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_APP_URL=https://sms.sekolah-contoh.sch.id
WEB_PORT=3000
API_INTERNAL_URL=http://api:4000

# --- Cloudflare Turnstile (REQUIRED in production) ---
# Production keys: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- Storage ---
STORAGE_PATH=/app/storage
REPORT_STORAGE_PATH=/app/storage/reports

# --- Sentry (production monitoring — RECOMMENDED) ---
# Get DSN: https://sentry.io/settings/<org>/projects/<project>/keys/
# SENTRY_DSN=https://examplePublicKey@o123456.ingest.sentry.io/654321
SENTRY_DSN=https://examplePublicKey@o123456.ingest.sentry.io/654321
SENTRY_ENVIRONMENT=production

# --- Seed (first deploy only) ---
# SEED_SUPER_ADMIN_EMAIL=superadmin@nexsmsid.dev
# SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
# SEED_SUPER_ADMIN_NAME="Super Admin NexSMSID"

# --- Optional ---
# PPDB_LEGACY_PIN_GRACE_END=2026-07-15T00:00:00.000Z
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=noreply@nexsmsid.dev
