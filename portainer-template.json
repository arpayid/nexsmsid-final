{
  "type": "stack",
  "title": "NexSMSID V4",
  "description": "Enterprise School Management System — PostgreSQL, Redis, NestJS API, Next.js Web, Nginx",
  "note": "Generated by agentfull deploy system",
  "categories": ["school", "management", "education"],
  "platform": "linux",
  "logo": "https://raw.githubusercontent.com/arpayid/nexsmsid-final/main/docs/logo.png",
  "repository": {
    "url": "https://github.com/arpayid/nexsmsid-final",
    "stackfile": "docker-compose.prod.yml"
  },
  "env": [
    {
      "name": "DOMAIN",
      "label": "Domain (opsional — untuk HTTPS)",
      "description": "Domain untuk HTTPS auto-config. Contoh: sms.sekolah.sch.id",
      "default": ""
    },
    {
      "name": "POSTGRES_PASSWORD",
      "label": "PostgreSQL Password",
      "description": "Wajib — set strong password (min 32 chars)"
    },
    {
      "name": "REDIS_PASSWORD",
      "label": "Redis Password",
      "description": "Wajib — set strong password (min 32 chars)"
    },
    {
      "name": "JWT_ACCESS_SECRET",
      "label": "JWT Access Secret",
      "description": "Wajib — min 64 chars. Generate: openssl rand -base64 64"
    },
    {
      "name": "JWT_REFRESH_SECRET",
      "label": "JWT Refresh Secret",
      "description": "Wajib — min 64 chars. Harus berbeda dari Access Secret"
    },
    {
      "name": "DATABASE_URL",
      "label": "Database URL",
      "description": "Auto: postgresql://nexsmsid:${POSTGRES_PASSWORD}@postgres:5432/nexsmsid",
      "default": "postgresql://nexsmsid:${POSTGRES_PASSWORD}@postgres:5432/nexsmsid"
    },
    {
      "name": "REDIS_URL",
      "label": "Redis URL",
      "description": "Auto: redis://:${REDIS_PASSWORD}@redis:6379",
      "default": "redis://:${REDIS_PASSWORD}@redis:6379"
    },
    {
      "name": "TURNSTILE_SECRET_KEY",
      "label": "Cloudflare Turnstile Secret Key",
      "description": "Wajib di production. Dapat dari Cloudflare Dashboard"
    },
    {
      "name": "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
      "label": "Cloudflare Turnstile Site Key",
      "description": "Wajib — pasangan dari secret key"
    },
    {
      "name": "WEB_ORIGIN",
      "label": "Web Origin URL",
      "description": "URL publik aplikasi. Contoh: https://sms.sekolah.sch.id",
      "default": "http://localhost:3000"
    },
    {
      "name": "CORS_ORIGIN",
      "label": "CORS Origin",
      "description": "Sama dengan WEB_ORIGIN biasanya"
    },
    {
      "name": "NEXT_PUBLIC_APP_URL",
      "label": "Next.js Public App URL",
      "description": "Sama dengan WEB_ORIGIN"
    },
    {
      "name": "SENTRY_DSN",
      "label": "Sentry DSN (opsional)",
      "description": "DSN untuk error tracking production",
      "default": ""
    },
    {
      "name": "BACKUP_SCHEDULE",
      "label": "Backup Schedule (cron)",
      "description": "Cron expression untuk auto-backup. Default: setiap 6 jam",
      "default": "0 */6 * * *"
    },
    {
      "name": "BACKUP_RETENTION_DAYS",
      "label": "Backup Retention (hari)",
      "description": "Lama penyimpanan backup sebelum dihapus",
      "default": "30"
    },
    {
      "name": "HEALTHCHECKS_URL",
      "label": "Healthchecks.io URL (opsional)",
      "description": "URL untuk ping monitoring eksternal",
      "default": ""
    },
    {
      "name": "S3_BUCKET",
      "label": "S3 Backup Bucket (opsional)",
      "description": "S3 bucket untuk offsite backup",
      "default": ""
    },
    {
      "name": "LOG_LEVEL",
      "label": "Log Level",
      "description": "error, warn, log, debug, verbose",
      "default": "log"
    }
  ],
  "volumes": [
    "postgres_data",
    "redis_data",
    "storage_data",
    "backup_data",
    "certbot_etc",
    "certbot_var"
  ]
}
